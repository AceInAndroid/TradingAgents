# LLM Providers (set the one you use)
OPENAI_API_KEY=
OPENAI_BASE_URL=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Bailian aliases for run_bailian.py
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Optional runtime overrides for run_analysis.py
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_MODEL_PRESET=balanced
TRADINGAGENTS_QUICK_THINK_LLM=
TRADINGAGENTS_DEEP_THINK_LLM=
TRADINGAGENTS_ANALYSTS=market,social,news,fundamentals
TRADINGAGENTS_TICKER=NVDA
TRADINGAGENTS_ANALYSIS_DATE=2024-05-10
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_DISCUSS_ROUNDS=1
TRADINGAGENTS_MAX_RECUR_LIMIT=30
TRADINGAGENTS_DEBUG=false

# Presets for run_bailian.py:
# balanced -> qwen3.5-plus / qwen3-max-2026-01-23
# fast     -> qwen3.5-plus / qwen3.5-plus
# coder    -> qwen3-coder-plus / qwen3-coder-next
# glm      -> glm-4.7 / glm-5
# kimi     -> kimi-k2.5 / kimi-k2.5
